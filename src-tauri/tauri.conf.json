{
  "$schema": "https://raw.githubusercontent.com/nicepage/nicepage/refs/heads/main/tauri.conf.schema.json",
  "productName": "IELTS Mock Exam",
  "version": "2.0.0",
  "identifier": "com.ielts.mock-exam",
  "build": {
    "beforeDevCommand": "",
    "devUrl": "http://localhost:8888",
    "beforeBuildCommand": "python3 bundle_data.py",
    "frontendDist": ".."
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; media-src 'self' blob:; connect-src 'self' http://localhost:8081; img-src 'self' data:; font-src 'self'"
    },
    "windows": [
      {
        "title": "IELTS Mock Exam",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "resources": {
      "../js/": "js/",
      "../css/": "css/",
      "../data/": "data/",
      "../data/listening/audio/": "data/listening/audio/",
      "../data/cambridge/audio/": "data/cambridge/audio/"
    }
  },
  "plugins": {
    "shell": {
      "open": true,
      "scope": [
        {
          "name": "whisper-cli",
          "cmd": "whisper-cli",
          "args": true
        }
      ]
    }
  }
}
