{
  "$schema": "https://raw.githubusercontent.com/nicepage/nicepage/refs/heads/main/tauri.conf.schema.json",
  "productName": "IELTS Mock Exam",
  "version": "2.0.0",
  "identifier": "com.ielts.mock-exam",
  "build": {
    "beforeDevCommand": "python3 -m http.server 8899 --bind 127.0.0.1",
    "devUrl": "http://localhost:8899",
    "beforeBuildCommand": "bash build-www.sh",
    "frontendDist": "../www"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; media-src 'self' blob: asset: http://asset.localhost *; connect-src 'self' http://localhost:8081 ipc: http://ipc.localhost; img-src 'self' data: asset: http://asset.localhost; font-src 'self'; object-src 'none'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'",
      "assetProtocol": {
        "enable": true,
        "scope": ["$RESOURCE/**"]
      }
    },
    "windows": [
      {
        "title": "IELTS Mock Exam",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "resources": {
      "../data/": "data/",
      "binaries/": "binaries/"
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
